PORT=3000
TZ=Asia/Jakarta

# PostgreSQL
PGHOST=localhost
PGPORT=5432
PGDATABASE=wrg_crm
PGUSER=wrg_admin
PGPASSWORD=WRG@CRM2026!

# WhatsApp gateway
# Mode: `mock` = log only (default). `http` = POST to WA_SEND_URL.
WA_SEND_MODE=mock
# Endpoint untuk mengirim pesan keluar. POST {to,target,text}.
WA_SEND_URL=
# Bearer token (opsional). Jika diset, dikirim sebagai Authorization header.
WA_SEND_TOKEN=
# Timeout per attempt (ms). Default 10s.
WA_HTTP_TIMEOUT_MS=10000
# Total retries setelah attempt pertama (jadi 2 = 1 + 2 = 3 total). 4xx tidak di-retry.
WA_HTTP_RETRIES=2
# Group identifiers — opaque string, akan diteruskan apa adanya ke gateway sebagai `target`.
WA_GROUP_ID=wrg-sales-command-center
WA_HOD_GROUP_ID=wrg-hod

# Rate limit (in-memory, fixed window 1 menit)
# Per-WA: kalau 1 nomor > N pesan/menit → 429. Default 20.
RATE_LIMIT_PER_WA_PER_MIN=20
# Global per-IP: total req/min dari 1 IP gateway. Default 600 (≈10/detik).
RATE_LIMIT_GLOBAL_PER_MIN=600
# Comma-separated WA numbers yang skip rate limit (mis. Husni untuk debug burst).
RATE_LIMIT_EXEMPT_WA=

# Auto-resend reply yang gagal
# Max attempts: setelah N kali coba dan masih gagal, hentikan (status=exhausted).
RESEND_MAX_ATTEMPTS=3
# Backoff antar attempt (menit).
RESEND_BACKOFF_MIN=5
# TTL: jangan resurrect failure yang lebih lama dari ini (jam).
RESEND_TTL_HOURS=24
# Berapa baris yang di-claim per batch tick (cron tiap 5 menit).
RESEND_BATCH_SIZE=20

# Dashboard untuk Husni / HOD
# Wajib di-set untuk mengaktifkan /dashboard. Kosong → endpoint balas 503.
# Bagikan URL: http://host:port/dashboard?token=<TOKEN_INI>
DASHBOARD_TOKEN=

# Alerting on exhausted resends
# Webhook untuk Slack / Discord-with-/slack / Telegram-via-adapter / etc.
# Kosong → channel http-webhook disabled. Format payload: { text, attachments }.
ALERT_WEBHOOK_URL=
ALERT_WEBHOOK_TIMEOUT_MS=5000
# Best-effort WA DM ke Husni (catatan: gagal kalau gateway-nya yang lagi down).
ALERT_WA_NUMBER=
# Debounce: jangan fire alert exhausted_resend yang sama dalam N menit.
ALERT_DEBOUNCE_MIN=30
# Escalation: kalau alert exhausted_resend tetap unresolved selama N menit,
# fire critical-level follow-up. Default 15 menit.
ALERT_ESCALATE_AFTER_MIN=15

# Email digest (weekly, Senin pagi)
# Set true untuk aktifkan. False → cron tidak di-register, endpoint tetap bisa
# dry-run (mode=json).
EMAIL_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
# true untuk port 465 (TLS), false untuk 587 (STARTTLS).
SMTP_SECURE=false
EMAIL_FROM=WRG CRM <noreply@wahanalifeline.co.id>
# Penerima — comma-separated. Kosong → tidak ada email yang dikirim.
EMAIL_HOD_RECIPIENTS=
# Cron format. Default Senin 08:00 WIB (recap minggu yang baru lewat).
EMAIL_DIGEST_CRON=0 8 * * 1

# Google OAuth (SSO untuk dashboard)
# Kalau kosong → fallback ke DASHBOARD_TOKEN saja (backward compat).
# Setup: Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID
# Authorized redirect URI: {OAUTH_BASE_URL}/auth/google/callback
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
# Domain hosting (Google Workspace) untuk membatasi siapa yang boleh login.
# Misal "wahanalifeline.co.id" → hanya @wahanalifeline.co.id yang bisa masuk.
OAUTH_GOOGLE_HD=
# Optional comma-separated email allowlist. Mengoverride HD: kalau diset,
# hanya email persis di list yang bisa login.
OAUTH_EMAIL_ALLOWLIST=
# Public base URL (untuk redirect_uri). Wajib match dengan yang di-register
# di Google Cloud Console.
OAUTH_BASE_URL=http://localhost:3000
# Session lifetime
SESSION_TTL_DAYS=7

# ── AI / LLM via OpenRouter ───────────────────────────────
# OpenRouter (https://openrouter.ai) — LLM gateway aggregator.
# Dipakai untuk: AI-generated daily summary narrative (di summary/format.ts).
# Kalau kosong → semua narrative fallback ke template deterministik.
OPENROUTER_API_KEY=
# Model — daftar lengkap di https://openrouter.ai/models
# Default openai/gpt-4o-mini: cheap (~$0.15/1M input tokens), fast, sufficient quality.
# Alternatif murah: google/gemini-2.0-flash-001, anthropic/claude-3-haiku.
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_TIMEOUT_MS=10000
# Optional analytics tagging — muncul di OpenRouter dashboard.
OPENROUTER_REFERER=https://github.com/DevWRG/wrg-crm
OPENROUTER_APP_TITLE=WRG CRM
